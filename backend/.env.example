# Rename this file to .env and fill in the real values before starting the server

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb+srv://user:password@cluster0.mongodb.net/mydb?retryWrites=true&w=majority

# AI service
AI_API_KEY=your_openai_or_groq_api_key
# Optional if you use a non-default base URL (Groq, Gemini, etc.)
#AI_BASE_URL=https://api.groq.com/openai/v1
#AI_MODEL=llama-3.3-70b-versatile

# General
PORT=4000
USE_HTTPS=false
SSL_KEY_PATH=
SSL_CERT_PATH=
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Encryption key (base64) used by crypto util, if needed
#ENC_KEY_BASE64=

# Email settings (either use SENDGRID_API_KEY or SMTP credentials)
#SENDGRID_API_KEY=
EMAIL_MODE=mock        # set to "smtp" or "production" when sending for real
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=you@example.com
EMAIL_PASSWORD=yourpassword
EMAIL_FROM="Digital Health <noreply@domain.com>"

# Other secrets
# any other environment variables used by the app
